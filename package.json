{
    "title": "Guillaume Sainthillier",
    "name": "sainthillier",
    "version": "1.2.0",
    "private": true,
    "description": "https://sainthillier.fr",
    "homepage": "https://sainthillier.fr",
    "license": "MIT",
    "type": "module",
    "author": "Guillaume Sainthillier",
    "contributors": [
        "David Miller (http://davidmiller.io/)"
    ],
    "scripts": {
        "dev": "vite build --mode development",
        "watch": "vite build --watch --mode development",
        "build": "vite build",
        "build:hugo": "yarn build && yarn hugo",
        "build:hugo:preview": "yarn build && yarn hugo -D -F",
        "hugo": "hugo --gc --minify",
        "hugo:dev": "hugo server -D",
        "prepare": "husky install",
        "lint": "biome check --write assets",
        "lint-ci": "biome check assets",
        "prettier": "prettier --write \"**/*.{css,md,yml,yaml}\"",
        "prettier:check": "prettier --check \"**/*.{css,md,yml,yaml}\"",
        "format": "yarn lint && yarn prettier",
        "knip": "knip",
        "knip:fix": "knip --fix",
        "size:json": "node scripts/bundle-size.js"
    },
    "dependencies": {
        "@webcomponents/custom-elements": "^1.6.0",
        "lazysizes": "^5.3.2",
        "lite-youtube-embed": "^0.3.3",
        "lucide": "^1.0.0",
        "wordcloud": "^1.2.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.16",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^24.0.0",
        "hugo-extended": "^0.162.0",
        "husky": "9.1.7",
        "knip": "^6.0.0",
        "lint-staged": ">=16.2.6",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4.1.18",
        "terser": "^5.37.0",
        "typescript": "^6.0.0",
        "vite": "^8"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,json}": "biome check --write --no-errors-on-unmatched",
        "*.{css,md,yaml,yml}": "prettier --write"
    }
}
